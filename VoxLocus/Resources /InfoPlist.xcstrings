{
  "sourceLanguage" : "en",
  "strings" : {
    "CFBundleName" : {
      "comment" : "Bundle name",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "VoxLocus"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus kann dir im Hintergrund Notizen vorschlagen, wenn du an einem Ort ankommst, an dem du bereits Notizen erstellt hast."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus can suggest notes in the background when you arrive at a place you've taken notes before."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus versieht Notizen mit deinem Standort und schlägt passende Notizen vor, wenn du an einen Ort zurückkehrst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus tags notes with your location and suggests relevant notes when you return to a place."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus nimmt deine Stimme auf, um deine Gedanken in Notizen umzuwandeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus records your voice to transcribe your thoughts into notes."
          }
        }
      }
    },
    "NSRemindersUsageDescription" : {
      "comment" : "Privacy - Reminders Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus kann Erinnerungen aus Aktionspunkten erstellen, die es in deinen Notizen erkennt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus can create Reminders from action items it detects in your notes."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Privacy - Speech Recognition Usage Description",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus verwendet Spracherkennung, um deine Aufnahmen in Text umzuwandeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "VoxLocus uses Speech Recognition to convert your recordings into text."
          }
        }
      }
    }
  },
  "version" : "1.2"
